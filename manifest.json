{
    "action": {
        "default_icon": "icon.svg",
        "default_title": "Get reviews"
    },
    "browser_specific_settings": {
        "gecko": {
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            },
            "id": "cleveland-streamer@example.com"
        }
    },
    "content_scripts": [
        {
            "css": ["style.css"],
            "js": ["inject.js"],
            "matches": ["*://www.netflix.com/browse*"],
            "run_at": "document_end"
        }
    ],
    "description": "See reviews for titles from within your favourite streaming service so you don't get stuck watching a Cleveland Streamer.",
    "icons": {
        "32": "icon.svg",
        "48": "icon.svg",
        "64": "icon.svg",
        "96": "icon.svg"
    },
    "manifest_version": 3,
    "name": "Cleveland Streamer",
    "version": "1.0"
}
